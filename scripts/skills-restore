#!/usr/bin/env bash
#
# Reinstala todas las skills del registro a scope global desde el lock
# committeado (.agents/.skill-lock.json).
#
# El CLI de `npx skills` NO tiene un restore-desde-lock para skills globales
# (experimental_install solo lee el lock de project: <cwd>/skills-lock.json).
# Esto replica su logica interna (agrupar por source -> skills add) pero con -g.
#
# Uso:
#   scripts/skills-restore            reinstala todo
#   scripts/skills-restore --dry-run  solo imprime lo que haria
#
# Nota: cada `skills add` puede reportar "Failed to install 1 -> PromptScript"
# (ese agente no soporta scope global); es inofensivo. El script tolera fallos
# parciales y sigue con el resto de los sources, avisando al final.
#
set -uo pipefail

DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOCK="$DIR/.agents/.skill-lock.json"
DRY_RUN=0
[ "${1:-}" = "--dry-run" ] && DRY_RUN=1

[ -f "$LOCK" ] || { echo "No existe el lock: $LOCK" >&2; exit 1; }

# Instalar solo a los agentes que usas (lastSelectedAgents del lock), con un
# -a por agente (el CLI NO acepta -a comma/space-separated, solo repetido).
# Esto ademas evita PromptScript, que no soporta scope global y ensuciaba la
# salida con un "Failed to install" por cada skill.
AGENT_FLAGS=()
while IFS= read -r ag; do
  [ -n "$ag" ] && AGENT_FLAGS+=(-a "$ag")
done < <(node -e '
const a = (require(process.argv[1]).lastSelectedAgents || ["claude-code"])
  .filter(x => x !== "promptscript");
for (const x of a) console.log(x);
' "$LOCK")
[ "${#AGENT_FLAGS[@]}" -eq 0 ] && AGENT_FLAGS=(-a claude-code)

# Agrupa las skills por source (ignora entradas node_modules) y emite
# lineas "source<TAB>skill1 skill2 ...". Los nombres van separados por espacio
# porque el flag -s del CLI espera args separados, NO comma-separated.
gen_pairs() {
  node -e '
const lock = require(process.argv[1]);
const bySource = {};
for (const [name, e] of Object.entries(lock.skills || {})) {
  if (e.sourceType === "node_modules") continue;
  const src = e.ref ? `${e.source}#${e.ref}` : e.source;
  (bySource[src] ||= []).push(name);
}
for (const [src, skills] of Object.entries(bySource))
  console.log(src + "\t" + skills.join(" "));
' "$LOCK"
}

# El loop lee los pares por el fd 3 (no por stdin): `npx skills add` consume
# stdin para su TUI, y si el loop leyera por stdin le robaria las lineas
# restantes y solo instalaria el primer source.
failed=()
while IFS=$'\t' read -r -u 3 source skills; do
  [ -n "$source" ] || continue
  echo ">> npx skills add $source -g -s $skills ${AGENT_FLAGS[*]} -y"
  [ "$DRY_RUN" = 1 ] && continue
  # $skills SIN comillas a proposito: se expande en varios args (uno por skill).
  if ! npx --yes skills add "$source" -g -s $skills "${AGENT_FLAGS[@]}" -y; then
    echo "   ⚠ fallo parcial en $source — sigo con el resto"
    failed+=("$source")
  fi
done 3< <(gen_pairs)

if [ "${#failed[@]}" -gt 0 ]; then
  echo "Terminado con avisos en: ${failed[*]}"
  echo "(revisa esos sources; el resto quedo instalado)"
else
  echo "Listo. Todas las skills reinstaladas."
fi
